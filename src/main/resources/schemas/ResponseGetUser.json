{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "required": [
    "data",
    "support",
    "_meta"
  ],
  "properties": {
    "data": {
      "type": "object",
      "required": [
        "id",
        "email",
        "first_name",
        "last_name",
        "avatar"
      ],
      "properties": {
        "id": {
          "type": "number"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "first_name": {
          "type": "string",
          "pattern": "^[A-Za-zÁÉÍÓÚáéíóúñÑ ._-]*$"
        },
        "last_name": {
          "type": "string",
          "pattern": "^[A-Za-zÁÉÍÓÚáéíóúñÑ ._-]*$"
        },
        "avatar": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "support": {
      "type": "object",
      "required": [
        "url",
        "text"
      ],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "text": {
          "type": "string"
        }
      }
    },
    "_meta": {
      "type": "object",
      "required": [
        "powered_by",
        "docs_url",
        "upgrade_url",
        "example_url",
        "variant",
        "message",
        "cta",
        "context"
      ],
      "properties": {
        "powered_by": {
          "type": "string",
          "pattern": "^[A-Za-z0-9 ._-]*$"
        },
        "docs_url": {
          "type": "string",
          "format": "uri"
        },
        "upgrade_url": {
          "type": "string",
          "format": "uri"
        },
        "example_url": {
          "type": "string",
          "format": "uri"
        },
        "variant": {
          "type": "string",
          "pattern": "^[A-Za-z0-9 _-]*$"
        },
        "message": {
          "type": "string"
        },
        "cta": {
          "type": "object",
          "required": [
            "label",
            "url"
          ],
          "properties": {
            "label": {
              "type": "string"
            },
            "url": {
              "type": "string",
              "format": "uri"
            }
          }
        },
        "context": {
          "type": "string",
          "pattern": "^[A-Za-z0-9 _-]*$"
        }
      }
    }
  }
}
